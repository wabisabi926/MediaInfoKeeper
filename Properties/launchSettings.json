{
  "profiles": {
    "EmbyPlugin": {
      "commandName": "Executable",
      "executablePath": "sh",
      "commandLineArgs": "./Scripts/restart_emby.sh",
      "workingDirectory": ".",
      "_comment_windows": "Windows: powershell -ExecutionPolicy Bypass -File restart_emby.ps1"
    },
    "EmbyServer": {
      "commandName": "Executable",
      "executablePath": "%AppData%\\Emby-Server\\system\\EmbyServer.exe",
      "commandLineArgs": "-nointerface",
      "workingDirectory": "%AppData%\\Emby-Server\\system"
    }
  }
}
